{%- liquid
  assign _scope = css_scope | default: ''
  if _scope != blank
    assign _prefix = _scope | append: ' '
  else
    assign _prefix = ''
  endif
-%}
{{ _prefix }}.ci-page {
  color: var(--foreground, currentColor);
  background: var(--background, transparent);
  min-height: 50vh;
}

{{ _prefix }}.ci-main-box {
  width: 100%;
}

{{ _prefix }}.ci-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

{{ _prefix }}.ci-heading h1,
{{ _prefix }}.ci-heading h2,
{{ _prefix }}.ci-heading h3 {
  margin: 0;
}

{{ _prefix }}.ci-continue-link,
{{ _prefix }}.ci-continue-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  gap: 0.5rem;
  color: inherit;
  text-decoration: none;
  white-space: nowrap;
}

{{ _prefix }}.ci-warnings {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
  padding: clamp(2rem, 8vw, 5rem) 1rem;
  text-align: center;
}

{{ _prefix }}.ci-warnings-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

{{ _prefix }}.ci-warnings-title,
{{ _prefix }}.ci-login-title,
{{ _prefix }}.ci-login-paragraph {
  margin: 0;
}

{{ _prefix }}.ci-login-paragraph {
  max-width: 42rem;
}

{{ _prefix }}.ci-container {
  display: flex;
  flex-direction: column;
  gap: 0;
}

{{ _prefix }}.ci-container.horizontal {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 380px);
  align-items: start;
  gap: clamp(2rem, 4vw, 3.5rem);
}

{{ _prefix }}.ci-container.horizontal ai-cart-items,
{{ _prefix }}.ci-container.horizontal ai-cart-drawer-items {
  min-width: 0;
  width: 100%;
}

{{ _prefix }}.ci-container.vertical {
  display: flex;
  flex-direction: column;
}

{{ _prefix }}.ci-form,
{{ _prefix }}.ci-contents {
  min-width: 0;
  width: 100%;
}

{{ _prefix }}.ci-contents {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  overflow: hidden;
}

{{ _prefix }}.ci-group {
  min-width: 0;
}

{{ _prefix }}.ci-group-nav {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0 0 0.75rem;
}

{{ _prefix }}.ci-group-nav-title {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  min-width: 0;
}

{{ _prefix }}.ci-group-nav-title svg {
  flex-shrink: 0;
}

{{ _prefix }}.ci-group-discount-name {
  font-weight: 600;
}

{{ _prefix }}.ci-group-divider {
  width: 1px;
  align-self: stretch;
  background: currentColor;
  opacity: 0.25;
}

{{ _prefix }}.ci-group-intro {
  margin: 0;
  opacity: 0.72;
}

{{ _prefix }}ai-cart-line-item {
  position: relative;
  overflow: visible;
  transition: transform 0.2s ease-out;
  touch-action: pan-y;
}

{{ _prefix }}.ci-container.horizontal .ci-line,
{{ _prefix }}.ci-container.vertical .ci-line {
  display: flex;
  flex-direction: row;
  min-width: 0;
  padding: 1rem ;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}

{{ _prefix }}.ci-container.horizontal .ci-line {
  gap: 16px;
}

{{ _prefix }}.ci-container.vertical .ci-line {
  gap: 12px;
}

{{ _prefix }}.ci-line-image {
  align-self: flex-start;
  width: clamp(88px, 16vw, 126px);
  max-width: 32%;
  overflow: hidden;
  background: transparent;
}

{{ _prefix }}.ci-line-image a,
{{ _prefix }}.ci-line-image img {
  display: block;
}

{{ _prefix }}.ci-line-image img {
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  object-fit: cover;
}

{{ _prefix }}.ci-container.horizontal .ci-line-image {
  flex-shrink: 0;
}

{{ _prefix }}.ci-container.vertical .ci-line-image {
  flex-shrink: 0;
}

{{ _prefix }}.ci-container.horizontal .ci-line-body {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16px;
  min-width: 0;
}

{{ _prefix }}.ci-container.vertical .ci-line-body {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

{{ _prefix }}.ci-line-info {
  min-width: 0;
}

{{ _prefix }}.ci-container.horizontal .ci-line-info {
  flex: 1 1 0%;
}

{{ _prefix }}.ci-line-title,
{{ _prefix }}.ci-line-price,
{{ _prefix }}.ci-line-options,
{{ _prefix }}.ci-line-preorder,
{{ _prefix }}.ci-line-discounts {
  margin: 0 0 0.5rem;
}

{{ _prefix }}.ci-line-title-link {
  color: inherit;
  text-decoration: none;
}

{{ _prefix }}.ci-line-price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

{{ _prefix }}.ci-line-price-compare {
  text-decoration: line-through;
  opacity: 0.6;
}

{{ _prefix }}.ci-line-options {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  opacity: 0.72;
}

{{ _prefix }}.ci-line-preorder,
{{ _prefix }}.ci-line-discount {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  width: fit-content;
  padding: 0.25rem 0.5rem;
  border-radius: 999px;
}

{{ _prefix }}.ci-line-preorder {
  background: rgba(0, 0, 0, 0.06);
}

{{ _prefix }}.ci-line-discounts {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  padding: 0;
  list-style: none;
}

{{ _prefix }}.ci-line-discount {
  background: var(--accent);
  color: var(--accent-foreground);
}

{{ _prefix }}.ci-line-discount svg {
  flex-shrink: 0;
}

{{ _prefix }}.ci-line-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.75rem;
}

{{ _prefix }}.ci-line-actions-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

{{ _prefix }}.ci-line-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  padding: 0;
  border: none;
  background: transparent;
  color: inherit;
  cursor: pointer;
}

{{ _prefix }}.ci-error-message:empty {
  display: none;
}

{{ _prefix }}.ci-error-message {
  color: #b42318;
  font-size: 0.875rem;
  text-align: right;
}

{{ _prefix }}.ci-line-total {
  flex-shrink: 0;
  width: 8.5rem;
  text-align: right;
}

{{ _prefix }}.ci-line-extra {
  flex-basis: 100%;
  margin: 0;
  padding: 0;
  list-style: none;
  opacity: 0.72;
}

{{ _prefix }}ai-cart-quantity-input,
{{ _prefix }}ai-quantity-input,
{{ _prefix }}.ci-quantity {
  position: relative;
  display: inline-flex;
  align-items: center;
  border: 1px solid currentColor;
  border-radius: 4px;
  overflow: hidden;
}

{{ _prefix }}.qi-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border: none;
  background: transparent;
  color: inherit;
  cursor: pointer;
}

{{ _prefix }}.qi-btn:hover,
{{ _prefix }}.ci-line-remove:hover,
{{ _prefix }}.ci-swipe-remove:hover {
  opacity: 0.75;
}

{{ _prefix }}.qi-input {
  width: 40px;
  border: none;
  outline: none;
  background: transparent;
  color: inherit;
  font-size: inherit;
  text-align: center;
  -moz-appearance: textfield;
}

{{ _prefix }}.qi-input::-webkit-outer-spin-button,
{{ _prefix }}.qi-input::-webkit-inner-spin-button {
  margin: 0;
  -webkit-appearance: none;
}

{{ _prefix }}.progress-bar-container {
  position: absolute;
  right: 0;
  bottom: -3px;
  left: 0;
  height: 2px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.12);
}

{{ _prefix }}.progress-bar-container.hidden {
  display: none;
}

{{ _prefix }}.progress-bar,
{{ _prefix }}.progress-bar-value {
  height: 100%;
}

{{ _prefix }}.progress-bar-value {
  width: 42%;
  background: currentColor;
  animation: ci-progress 1s ease-in-out infinite;
}

{{ _prefix }}.cart__items--disabled {
  pointer-events: none;
}

{{ _prefix }}.cf-footer {
  min-width: 0;
  width: 100%;
}

{{ _prefix }}.ci-container.horizontal .cf-footer {
  position: sticky;
  top: 1.5rem;
}

{{ _prefix }}.cf-inner {
  min-width: 0;
  width: 100%;
}

{{ _prefix }}.cf-blocks {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  width: 100%;
}

{{ _prefix }}.cf-totals {
  display: flex;
  flex-direction: column;
  gap: 0
}

{{ _prefix }}.cf-subtotal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}

{{ _prefix }}.cf-subtotal-price {
  margin: 0;
}

{{ _prefix }}.cf-tax-note {
  opacity: 0.72;
}

{{ _prefix }}.cf-error:empty {
  display: none;
}

{{ _prefix }}.cf-error {
  color: #b42318;
}

{{ _prefix }}.cf-ctas {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  width: 100%;
}

{{ _prefix }}.cf-checkout-btn {
  width: 100%;
}

{{ _prefix }}.cf-checkout-btn:disabled,
{{ _prefix }}.qi-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

{{ _prefix }}.ci-live-region {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

{{ _prefix }}.ci-page--empty .ci-heading,
{{ _prefix }}.ci-page:not(.ci-page--empty) .ci-warnings,
{{ _prefix }}.cd-body.is-empty .cd-container,
{{ _prefix }}.cd-body:not(.is-empty) .cd-empty {
  display: none;
}

{{ _prefix }}ai-cart-drawer {
  visibility: hidden;
}

{{ _prefix }}ai-cart-drawer[data-state="open"],
{{ _prefix }}ai-cart-drawer.active {
  visibility: visible;
}

{{ _prefix }}.cd-overlay {
  z-index: 99;
  background: rgba(0, 0, 0, 0);
  transition: background 0.3s ease;
}

{{ _prefix }}ai-cart-drawer.active .cd-overlay {
  background: rgba(0, 0, 0, 0.5);
}

{{ _prefix }}.cd-panel {
  z-index: 100;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

{{ _prefix }}ai-cart-drawer.active .cd-panel {
  transform: translateX(0);
}

{{ _prefix }}.cn-notification {
  display: none;
}

{{ _prefix }}.cn-notification.active {
  display: block;
}

{{ _prefix }}.ci-swipe-action {
  position: absolute;
  top: 0;
  bottom: 0;
  inset-inline-end: -76px;
  width: 76px;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1;
  visibility: hidden;
}

{{ _prefix }}ai-cart-line-item.is-swiping .ci-swipe-action {
  visibility: visible;
}

{{ _prefix }}.ci-swipe-remove {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 76px;
  height: 100%;
  gap: 0.25rem;
  padding: 0 0.5rem;
  border: 0;
  background: #b42318;
  color: #ffffff;
  cursor: pointer;
}

{{ _prefix }}.ci-swipe-remove p {
  margin: 0;
  font-size: 0.75rem;
  line-height: 1.2;
}

@media (max-width: 1120px) {
  {{ _prefix }}.ci-container.horizontal {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  {{ _prefix }}.ci-container.horizontal .cf-footer {
    position: static;
    width: 100%;
  }
}

@media (max-width: 749px) {
  {{ _prefix }}.ci-line-body {
    flex-direction: column !important;
    align-items: flex-start;
  }

  {{ _prefix }}.ci-line-image {
    align-self: flex-start;
    background: transparent !important;
  }

  {{ _prefix }}.ci-line-actions {
    align-items: flex-start;
  }

  {{ _prefix }}.ci-line-total {
    text-align: left;
  }

  {{ _prefix }}.ci-swipe-action {
    display: flex;
  }

  {{ _prefix }}ai-cart-remove-btn:not(.ci-swipe-remove) {
    display: none;
  }
}

@keyframes ci-progress {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(240%);
  }
}

  {% comment %} 渲染空星 {% endcomment %}
  {% assign shown_stars = full_stars %}
  {% if show_half_star %}
    {% assign shown_stars = shown_stars | plus: 1 %}
  {% endif %}
  
  {% assign empty_count = max_stars | minus: shown_stars %}
  {% for i in (1..empty_count) %}
    {% case icon_type %}
      {% when 'star' %}
        <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 16 16" fill="none">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M7.09195 1.53135C7.44936 0.756477 8.55065 0.756477 8.90807 1.53135L10.3805 4.72367L13.8716 5.13759C14.719 5.23807 15.0593 6.28545 14.4328 6.86482L11.8518 9.25171L12.5369 12.6999C12.7032 13.5368 11.8123 14.1841 11.0677 13.7673L8.00001 12.0502L4.93235 13.7673C4.18774 14.1841 3.29678 13.5368 3.46308 12.6999L4.14823 9.25171L1.56717 6.86482C0.940669 6.28545 1.28099 5.23807 2.12838 5.13759L5.61948 4.72367L7.09195 1.53135ZM8.00001 2.21547L6.60238 5.24553C6.45671 5.56134 6.15743 5.77878 5.81206 5.81973L2.49842 6.21261L4.94828 8.47818C5.20362 8.71431 5.31793 9.06614 5.25015 9.40725L4.59984 12.6801L7.51157 11.0503C7.81504 10.8804 8.18498 10.8804 8.48845 11.0503L11.4002 12.6801L10.7499 9.40725C10.6821 9.06614 10.7964 8.71431 11.0517 8.47818L13.5016 6.21261L10.188 5.81973C9.84259 5.77878 9.54331 5.56134 9.39764 5.24553L8.00001 2.21547Z" fill="{{ icon_color }}"/>

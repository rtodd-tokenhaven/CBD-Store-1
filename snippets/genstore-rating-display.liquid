{% comment %}
  SVG星级组件 - 添加半星逻辑
  支持半星、半钻石、半心、半皇冠
  小数部分处理规则：
    - 小于0.3：空星处理
    - 大于等于0.3和小于等于0.7：半星处理
    - 大于0.7：满星处理
{% endcomment %}

{% assign max_stars = max_count |default: 5 %}
{% assign icon_size = font_size | default: 16 %}
{% assign icon_spacing = spacing | default: 4 %}
{% assign empty_color = icon_color | default: '#D92027' %}
{% assign is_half_star = half_star | default: false %}
{% assign review_counts = review_count | default: 0 %}
{% unless icon_color %}
  {% case icon_type %}
    {% when 'star' %}{% assign icon_color = '#D92027' %}
    {% when 'masonry' %}{% assign icon_color = '#D92027' %}
    {% when 'love' %}{% assign icon_color = '#D92027' %}
    {% when 'crown' %}{% assign icon_color = '#D92027' %}
    {% else %}{% assign icon_color = '#D92027' %}
  {% endcase %}
{% endunless %}

{% comment %} 计算星星显示逻辑 - 新增小数处理规则 {% endcomment %}
{% assign rating_float = rating_score | default: 0 | times: 1.0 %}
{% if is_half_star %}
{% assign full_stars = rating_float | floor %}
{% assign decimal_part = rating_float | minus: full_stars %}
{% else %}
  {% assign full_stars = rating_float | round %}
  {% assign decimal_part = 0 %}
{% endif %}
{% assign show_half_star = false %}

{% comment %} 根据小数部分决定是否显示半星 {% endcomment %}
{% if decimal_part >= 0.3 and decimal_part <= 0.7 %}
  {% assign show_half_star = true %}
{% elsif decimal_part > 0.7 %}
  {% assign full_stars = full_stars | plus: 1 %}
{% endif %}

<style>
  .rating-simple {
    display: inline-flex;
    align-items: center;
    gap: {{ icon_spacing }}px;
    font-family: Arial, sans-serif;
    line-height:16px;
  }
  
  .rating-simple svg {
    display: block;
  }
  
  .review-info {
    margin-left: 8px;
    font-size: 14px;
    color: #333;
  }
  
  .review-count {
    color: var(--genstore-neutral-texticon-900, rgba(0, 0, 0, 0.90));
    font-family: Outfit;
    font-size: var(--genstore-fontSizes-250, 13px);
    font-style: normal;
    font-weight: var(--genstore-fontWeights-regular, 400);
    line-height: 16px; /* 123.077% */
  }
  
  {% comment %} 半星容器样式 {% endcomment %}
  .half-icon-container {
    position: relative;
    width: {{ icon_size }}px;
    height: {{ icon_size }}px;
  }
  
  .half-icon-left {
    position: absolute;
    left: 0;
    top: 0;
    width: 50%;
    height: 100%;
    overflow: hidden;
  }
  
  .half-icon-right {
    position: absolute;
    right: 0;
    top: 0;
    width: 50%;
    height: 100%;
    overflow: hidden;
  }
  @media screen and (max-width:750px){
  .review-info{
     display:none
  }
  }
</style>


{% comment %}
  Renders social icons.
  Accepts:
  - class: {String} a class to be added to the <ul> element (optional).
  Usage:
  {% render 'ai-social-icons',
  class: 'my-class'
  %}
{% endcomment %}

{%- liquid
  assign allSocials = 'social_facebook_link,social_instagram_link,social_youtube_link,social_tiktok_link,social_twitter_link,social_pinterest_link,social_snapchat_link,social_tumblr_link,social_vimeo_link' | split: ','
  assign hasSetSocial = false
  for social in allSocials
    if settings[social] != blank
      assign hasSetSocial = true
      break
    endif
  endfor
-%}
<ul class="list-unstyled list-social{% if class %} {{ class}}{% endif %}" role="list">
  {% if hasSetSocial == false or settings.social_facebook_link != blank %}
    <li class="list-social__item">
      <a
        target="_blank"
        href="{%if  settings.social_facebook_link == blank%}https://www.facebook.com {%else%}{{ settings.social_facebook_link | shop_group: 'social_url' }}{% endif %}"
        class="link list-social__link"
        {{ '' | genstore_vkey: key:'social_facebook_link', group:'settings' }}
      >
        <span class="svg-wrapper">
          {{- 'icon-facebook.svg' | inline_asset_content -}}
        </span>
        <span class="visually-hidden">
          {{ 'general.social.links.facebook' | t }}
        </span>
      </a>
    </li>
  {% endif %}
  {% if hasSetSocial == false or settings.social_instagram_link != blank %}

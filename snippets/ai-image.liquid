{%- comment -%}
  ai-image — 图片组件
  封装占位图逻辑和 responsive loading

  参数：
    image       (image object)  Shopify image 对象
    src         (string)        直接 URL（与 image 二选一）
    alt         (string)        alt 文本
    ratio       (string)        宽高比 16:9/4:3/3:2/1:1/3:4/auto，默认 auto
    width       (number)        请求宽度 px，默认 1200
    class       (string)        额外 CSS 类
    style       (string)        额外内联样式
    vkey_attr   (string)        genstore_vkey 属性字符串（必须先 assign 到变量再传入，render 不支持内联 filter）
{%- endcomment -%}

{%- liquid
  assign _ratio = ratio | default: 'auto'
  assign _width = width | default: 1200
-%}

<div class="ai-image ai-image--{{ _ratio }}{% if class != blank %} {{ class }}{% endif %}"{% if style != blank %} style="{{ style }}"{% endif %} {{ vkey_attr }}>
  {%- if image != blank -%}
    <img src="{{ image | image_url: width: _width }}"
         alt="{{ alt | default: image.alt | escape }}"
         loading="lazy"
         width="{{ image.width }}"
         height="{{ image.height }}">
  {%- elsif src != blank -%}
    <img src="{{ src }}"
         alt="{{ alt | escape }}"
         loading="lazy">
  {%- else -%}
    <img src="https://assets-cdn.genstore.ai/web/ai-chat/static/221627f4-6050-4d8a-aee0-6d9e9299b3a0/Mock-01.png"
         alt="placeholder"
         loading="lazy">
  {%- endif -%}
</div>

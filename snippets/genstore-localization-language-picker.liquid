{%- comment -%}
  Renders the language picker for the localization form

  Accepts:
  - localPosition: pass in the position in which the form is coming up to create specific IDs
{%- endcomment -%}
{% capture slot_content %}
  {% render 'genstore-svg', icon_name: 'icon-down', className: "icon-caret" %}
{% endcapture %}
<div class="disclosure">
  <button
    type="button"
    class="disclosure__button localization-form__select localization-selector link link--text caption-large"
    aria-expanded="false"
    aria-controls="{{ localPosition }}List"
    aria-describedby="{{ localPosition }}Label">
    {% assign text = localization.language.endonym_name  %}
    {% render 'genstore-text-link', text_size: section.settings.menu_size, tag_type: "span", text: text, slot_content: slot_content, no_letter_spacing: true %}
  </button>
  <div class="disclosure__list-wrapper language-selector" hidden>
    <ul
      id="{{ localPosition }}List"
      role="list"
      class="disclosure__list list-unstyled">
      {%- for language in localization.available_languages -%}
        <li class="disclosure__item" tabindex="-1">
          <a
            class="link link--text disclosure__link caption-large focus-inset"
            href="#"
            hreflang="{{ language.iso_code }}"
            lang="{{ language.lang }}"
            {% if language.iso_code == localization.language.iso_code %}
              aria-current="true"
            {% endif %}
            data-value="{{ language.lang }}">
            {% liquid
              assign icon_class_name = 'icon-check'
              if language.iso_code != localization.language.iso_code
                assign icon_class_name = icon_class_name | append: ' ' | append: 'visibility-hidden'
              endif
            %}
            {% render 'genstore-svg', icon_name: "icon-check", className: icon_class_name %}
            <span>
              {% render 'genstore-text-block', text: language.endonym_name, text_size: 'xs', no_letter_spacing: true %}
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
<input
  type="hidden"
  name="locale_code"
  value="{{ localization.language.iso_code }}">

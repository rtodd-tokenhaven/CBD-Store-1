{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'block-image-content.css' | asset_url | stylesheet_tag }}
{{ 'component-button.css' | asset_url | stylesheet_tag }}

{%- capture image_banner_model_json -%}
  {%- render 'genstore-image-banner-model', section: section -%}
{%- endcapture -%}

{%- liquid
  assign image_banner_model = image_banner_model_json | strip | parse_json
  assign image_arr = image_banner_model.image_arr
  assign total_count = image_banner_model.total_count
  assign media_class = image_banner_model.media_class
  assign image_wrapper = image_banner_model.image_wrapper
  assign image_wrapper_vertial = image_banner_model.image_wrapper_vertical
  assign image_wrapper_layout = image_banner_model.image_wrapper_layout
-%}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign half_width = '60vw'
    assign full_width = '120vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  elsif section.settings.image_behavior == 'fixed' or section.settings.image_behavior == 'zoom-in'
    assign half_width = '100vw'
    assign stacked_sizes = '100vw'
  else
    assign half_width = '50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 100vw'
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  assign overlay_opacity = section.settings.image_overlay_opacity | divided_by: 100.0

  if total_count > 1 and section.settings.stack_images_on_mobile
    assign sizes = stacked_sizes
  elsif total_count > 1
    assign sizes = half_width
  else
    assign sizes = full_width
  endif

  if section.settings.image_2 == blank
    assign show_placeholder = true
  endif
-%}

<div
  id="Banner-{{ section.id }}"
  data-role="image-banner"
  data-section-id="{{ section.id }}"
  data-capabilities="overlay_scrim responsive_media content_blocks"
  data-image-banner-model="{{ image_banner_model_json | strip_newlines | escape }}"
  data-overlay-opacity="{{ overlay_opacity }}"
  style="--banner-overlay-opacity: {{ overlay_opacity }};"
  class="pointer-events-none image-banner banner banner--content-align-{{ section.settings.desktop_content_alignment }} banner--content-align-mobile-{{ section.settings.mobile_content_alignment }} banner--{{ section.settings.image_height }} section-mark disable-section-top-offset {{ image_wrapper }}{% if section.settings.stack_images_on_mobile and section.settings.image != blank and section.settings.image_2 != blank %} banner--stacked{% endif %}{% if section.settings.image_height == 'adapt' and section.settings.image != blank %} banner--adapt{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="f-row full-width media-banner-wrapper" data-role="image-banner:media">
    {% if total_count > 2 %}
      <div class="{{ media_class }} {{ image_wrapper_layout }} {{ image_wrapper_vertial }}" data-role="image-banner:media-group">
        {% for i in (1..2) %}
          {% assign index = i | minus: 1 %}
          {%- render 'image-banner-media',
            image_key: image_arr[index],
            section: section,
            aspect_ratio: section.settings.image_height,
            sizes: sizes,
            className: 'banner-media-item pointer-events-auto',
            widths: widths,
            fetch_priority: fetch_priority,
            data_role: 'image-banner:media-item',
            show_placeholder: show_placeholder
          -%}
        {% endfor %}
      </div>
      {%- liquid
        assign className = media_class | append: ' pointer-events-auto'
      -%}
      {%- render 'image-banner-media',
        image_key: image_arr[2],
        section: section,
        aspect_ratio: section.settings.image_height,
        sizes: sizes,
        className: className,
        widths: widths,
        fetch_priority: fetch_priority,
        data_role: 'image-banner:media-item',
        show_placeholder: show_placeholder
      -%}
    {% else %}
      {% for i in (1..total_count) %}
        {%- liquid
          assign index = i | minus: 1
          assign className = media_class | append: ' pointer-events-auto'
        -%}
        {%- render 'image-banner-media',
          image_key: image_arr[index],
          section: section,
          aspect_ratio: section.settings.image_height,
          sizes: sizes,
          className: className,
          widths: widths,
          fetch_priority: fetch_priority,
          data_role: 'image-banner:media-item',
          show_placeholder: show_placeholder
        -%}
      {% endfor %}
    {% endif %}
  </div>

  <div data-role="image-banner:content" class="banner__content{% if section.settings.enable_full_width_in_content == false %} page-width{% endif %}{% if section.settings.show_text_box == true %} enable-card{% else %} disabled-card{% endif %} banner__content-align-{{ section.settings.desktop_content_alignment }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}{% if section.settings.show_separator_line == true %} banner__content-separator_line{% endif %}">
    <div data-role="image-banner:content-container" class="banner__container banner__container--{{ section.settings.desktop_content_position }}">
      {% render 'image-blocks',
        blocks: section.blocks,
        opacity: section.settings.opacity,
        color_mode: section.settings.color_mode,
        color_style: section.settings.color_style,
        is_card: section.settings.show_text_box,
        has_padding: section.settings.show_text_box,
        data_role: 'image-banner:blocks'
      %}
    </div>
  </div>
</div>


  }

  #genstore-section-{{ section.id }} .ai-share-button__btn::-webkit-details-marker {
    display: none;
  }

  #genstore-section-{{ section.id }} .ai-share-button__btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  #genstore-section-{{ section.id }} .ai-share-button__fallback {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 8px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 6px;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-background, #fff);
    z-index: 10;
    min-width: 260px;
  }

  #genstore-section-{{ section.id }} .ai-share-field {

    padding: 0 20px;
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  /* Shopify payment_button 的 SSR 骨架（disabled + aria-hidden）在
     portable-wallets 初始化前不可交互；不要把它涂成可点的 CTA，
     等初始化完成（aria-hidden 被移除）后再展示。 */
  #genstore-section-{{ section.id }} .product-buy-now .shopify-payment-button__button[aria-hidden='true'] {

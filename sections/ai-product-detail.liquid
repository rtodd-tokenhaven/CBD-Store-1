{%- comment -%}
  sections/ai-product-detail.liquid — 商详页固定骨架（自研版）

  所有 HTML 结构和交互逻辑由系统提供，AI 只需编写 CSS。
  - 通过 <style> 标签在头部注入样式
  - 骨架内的 class 名全部保留，AI 通过选择器装修
  - 零外部依赖：不依赖 genstore-global.js，使用自研 ai-*.js Web Components
  - 子组件（price / variant-picker / buy-buttons / gallery）全部内联
{%- endcomment -%}

{%- liquid
  assign color_scheme = settings.theme_color_scheme | default: 'scheme-1'

  assign target = product.selected_or_first_available_variant
  assign desc_block = section.blocks | where: 'type', 'description' | first
  assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first
  assign product_form_id = 'product-form-' | append: section.id
  assign installment_form_id = 'product-form-installment-' | append: section.id
-%}

<style>
  #genstore-section-{{ section.id }} {
  {% render 'ai-color-tokens' %}
  background: var(--background);
  color: var(--foreground);
}

/* =============================================
   CONTAINER & PAGE LAYOUT
   ============================================= */
#genstore-section-{{ section.id }} .genstore-container {
  background: var(--background);
  color: var(--foreground);
  padding: 48px 0 64px;
}

#genstore-section-{{ section.id }} .product {
  gap: 48px;
}

/* =============================================
   MEDIA WRAPPER
   ============================================= */
#genstore-section-{{ section.id }} .product__media-wrapper {
  background: var(--background);
  border-radius: 10px;
  overflow: hidden;
}

#genstore-section-{{ section.id }} .product__media-placeholder {
  background: var(--secondary);
  color: var(--secondary-foreground);
  border-radius: 10px;
  min-height: 320px;
}

#genstore-section-{{ section.id }} .product-desc--gallery {
  color: var(--foreground);
  font-size: 0.875rem;
  line-height: 1.6;
  margin-top: 16px;
  padding: 0 4px;
  letter-spacing: 0.01em;
}

/* =============================================
   GALLERY MAIN
   ============================================= */
#genstore-section-{{ section.id }} .mg-main {
  border-radius: 10px;
  overflow: hidden;
  background: var(--secondary);
  aspect-ratio: 1 / 1;
}

#genstore-section-{{ section.id }} .mg-slide {
  background: var(--secondary);
  padding: 0;
}

#genstore-section-{{ section.id }} .mg-slide img,
#genstore-section-{{ section.id }} .mg-slide video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* =============================================
   GALLERY NAVIGATION
   ============================================= */
#genstore-section-{{ section.id }} .mg-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 10px 0 4px;
}

#genstore-section-{{ section.id }} button.mg-prev,
#genstore-section-{{ section.id }} button.mg-next {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid currentColor;
  background: transparent;
  color: var(--foreground);
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  opacity: 0.75;
}

#genstore-section-{{ section.id }} button.mg-prev:hover,
#genstore-section-{{ section.id }} button.mg-next:hover {
  background: var(--brand);
  color: var(--brand-foreground);
  border-color: var(--brand);
  opacity: 1;
}

#genstore-section-{{ section.id }} .mg-counter {
  font-size: 0.8125rem;
  letter-spacing: 0.08em;
  color: var(--foreground);
  opacity: 0.7;
  display: flex;
  align-items: center;
  gap: 3px;
}

/* =============================================
   THUMBNAILS
   ============================================= */
#genstore-section-{{ section.id }} .mg-thumbnails {
  margin-top: 12px;
  padding: 0 2px;
}

#genstore-section-{{ section.id }} button.mg-thumb {
  border-radius: 6px;
  border: 2px solid transparent;
  overflow: hidden;
  opacity: 0.6;
  cursor: pointer;
  transition: border-color 0.2s, opacity 0.2s;
  background: var(--secondary);
  width: 64px;
  height: 64px;
  flex-shrink: 0;
}

#genstore-section-{{ section.id }} button.mg-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

#genstore-section-{{ section.id }} button.mg-thumb:hover {
  opacity: 0.85;
  border-color: var(--brand);
}

#genstore-section-{{ section.id }} .mg-thumb--active {
  border-color: var(--brand) !important;
  opacity: 1 !important;
}

/* =============================================
   PRODUCT INFO WRAPPER & CONTAINER
   ============================================= */
#genstore-section-{{ section.id }} .product__info-wrapper {
  background: var(--background);
  border-radius: 10px;
  padding: 0;
}

#genstore-section-{{ section.id }} .product__info-container {
  gap: 20px;
  padding: 8px 0 24px;
  background: var(--background);
  color: var(--foreground);
}

/* =============================================
   TAGS
   ============================================= */
#genstore-section-{{ section.id }} .product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

#genstore-section-{{ section.id }} .product-tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 100px;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--accent);
  color: var(--accent-foreground);
  border: none;
}

/* =============================================
   TITLE
   ============================================= */
#genstore-section-{{ section.id }} h2.product-title {
  font-size: clamp(1.5rem, 3vw, 2.125rem);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--foreground);
  margin: 0 0 4px;
}

/* =============================================
   SUBTITLE
   ============================================= */
#genstore-section-{{ section.id }} .product-subtitle {
  font-size: 1rem;
  color: var(--foreground);
  opacity: 0.65;
  font-weight: 400;
  letter-spacing: 0.01em;
  margin: 0;
}

/* =============================================
   TEXT / CONTENT BLOCKS
   ============================================= */
#genstore-section-{{ section.id }} .product-content {
  color: var(--foreground);
  line-height: 1.7;
  font-size: 0.9375rem;
  opacity: 0.85;
}

/* =============================================
   VENDOR & DELIVERY
   ============================================= */
#genstore-section-{{ section.id }} .vendor-and-delivery {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
}

#genstore-section-{{ section.id }} .vendor-item,
#genstore-section-{{ section.id }} .delivery-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  color: var(--foreground);
  opacity: 0.7;
  letter-spacing: 0.02em;
}

#genstore-section-{{ section.id }} .vendor-item svg,
#genstore-section-{{ section.id }} .delivery-item svg {
  stroke: currentColor;
  fill: none;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

/* =============================================
   PRICE
   ============================================= */
#genstore-section-{{ section.id }} .product-price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px;
}

#genstore-section-{{ section.id }} .product-price [data-product-price] {
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--foreground);
}

#genstore-section-{{ section.id }} .price--on-sale [data-product-price] {
  color: var(--striking-foreground);
  background: var(--striking);
  padding: 2px 8px;
  border-radius: 4px;
}

#genstore-section-{{ section.id }} .price--on-sale [data-product-compare-price] {
  text-decoration: line-through;
  opacity: 0.5;
  font-size: 1rem;
  font-weight: 400;
  color: var(--foreground);
}

#genstore-section-{{ section.id }} .product-badge[data-product-badge] {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--accent);
  color: var(--accent-foreground);
}

/* =============================================
   PRICE PER ITEM / VOLUME PRICING
   ============================================= */
#genstore-section-{{ section.id }} .product-price-per-item {
  font-size: 0.8125rem;
  color: var(--foreground);
  opacity: 0.6;
  letter-spacing: 0.01em;
}

#genstore-section-{{ section.id }} .product-volume-pricing {
  border: 1px solid var(--secondary);
  border-radius: 8px;
  padding: 12px 16px;
  background: var(--secondary);
  color: var(--secondary-foreground);
  font-size: 0.875rem;
  line-height: 1.6;
}

#genstore-section-{{ section.id }} .product-volume-note {
  font-size: 0.8125rem;
  color: var(--foreground);
  opacity: 0.6;
  margin-top: 4px;
}

/* =============================================
   SKU
   ============================================= */
#genstore-section-{{ section.id }} .product-sku {
  font-size: 0.8125rem;
  color: var(--foreground);
  opacity: 0.5;
  letter-spacing: 0.04em;
}

#genstore-section-{{ section.id }} .product-sku [data-product-sku] {
  color: inherit;
}

/* =============================================
   SEPARATOR
   ============================================= */
#genstore-section-{{ section.id }} hr.product-separator {
  border: none;
  border-top: 1px solid var(--secondary);
  margin: 4px 0;
  opacity: 0.6;
}

/* =============================================
   INVENTORY & SHARE
   ============================================= */
#genstore-section-{{ section.id }} .product__inventory {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  padding: 4px 10px;
  border-radius: 100px;
}

#genstore-section-{{ section.id }} .in-stock {
  background: var(--accent);
  color: var(--accent-foreground);
}

#genstore-section-{{ section.id }} .in-stock .inventory-status-text {
  color: inherit;
}

#genstore-section-{{ section.id }} .low-stock {
  background: var(--striking);
  color: var(--striking-foreground);
}

#genstore-section-{{ section.id }} .low-stock .inventory-status-text {
  color: inherit;
}

#genstore-section-{{ section.id }} .out-of-stock {
  background: var(--secondary);
  color: var(--secondary-foreground);
  opacity: 0.6;
}

#genstore-section-{{ section.id }} .out-of-stock .inventory-status-text {
  color: inherit;
}

#genstore-section-{{ section.id }} .inventory-quantity {
  color: inherit;
}

#genstore-section-{{ section.id }} a.product-share {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  color: var(--foreground);
  opacity: 0.65;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 1px;
  transition: opacity 0.2s;
}

#genstore-section-{{ section.id }} a.product-share:hover {
  opacity: 1;
}

#genstore-section-{{ section.id }} a.product-share svg {
  stroke: currentColor;
  fill: none;
  width: 15px;
  height: 15px;
}

/* =============================================
   DESCRIPTION ACCORDION
   ============================================= */
#genstore-section-{{ section.id }} .product-desc {
  font-size: 0.9375rem;
  line-height: 1.75;
  color: var(--foreground);
  opacity: 0.85;
}

#genstore-section-{{ section.id }} .product-desc .rich-text-content {
  color: var(--foreground);
}

#genstore-section-{{ section.id }} details.product__accordion {
  border-top: 1px solid var(--secondary);
  border-bottom: 1px solid var(--secondary);
}

#genstore-section-{{ section.id }} details.product__accordion summary.collapsible-title {
  cursor: pointer;
  padding: 14px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-weight: 600;
  font-size: 0.9375rem;
  letter-spacing: 0.01em;
  color: var(--foreground);
  list-style: none;
  user-select: none;
}

#genstore-section-{{ section.id }} details.product__accordion summary.collapsible-title svg.icon-caret {
  stroke: currentColor;
  fill: none;
  width: 18px;
  height: 18px;
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

#genstore-section-{{ section.id }} details[open] .icon-caret {
  transform: rotate(180deg);
}

#genstore-section-{{ section.id }} details.product__accordion .rich-text-content {
  padding: 0 0 16px;
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--foreground);
  opacity: 0.8;
}

/* =============================================
   COLLAPSIBLE TAB
   ============================================= */
#genstore-section-{{ section.id }} .collapsible-tab.accordion > details {
  border-top: 1px solid var(--secondary);
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details:last-child {
  border-bottom: 1px solid var(--secondary);
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details summary {
  cursor: pointer;
  padding: 14px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  list-style: none;
  user-select: none;
  color: var(--foreground);
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details summary .summary__title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 600;
  font-size: 0.9375rem;
  letter-spacing: 0.01em;
  color: var(--foreground);
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details summary svg.icon-accordion {
  stroke: currentColor;
  fill: none;
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details summary svg.icon-caret {
  stroke: currentColor;
  fill: none;
  width: 18px;
  height: 18px;
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

#genstore-section-{{ section.id }} .collapsible-tab.accordion > details .accordion__content.rich-text-content {
  padding: 0 0 16px;
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--foreground);
  opacity: 0.8;
}

/* =============================================
   POPUP
   ============================================= */
#genstore-section-{{ section.id }} .product-popup > details summary.product-popup__trigger {
  cursor: pointer;
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--foreground);
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  opacity: 0.7;
  transition: opacity 0.2s;
  user-select: none;
}

#genstore-section-{{ section.id }} .product-popup > details summary.product-popup__trigger:hover {
  opacity: 1;
}

#genstore-section-{{ section.id }} .product-popup > details .product-popup__content.rich-text-content {
  margin-top: 12px;
  padding: 16px;
  border: 1px solid var(--secondary);
  border-radius: 8px;
  background: var(--secondary);
  color: var(--secondary-foreground);
  font-size: 0.875rem;
  line-height: 1.7;
}

/* =============================================
   ICON WITH TEXT
   ============================================= */
#genstore-section-{{ section.id }} .product-icon-text {
  display: flex;
  gap: 16px;
}

#genstore-section-{{ section.id }} .product-icon-text--horizontal {
  flex-direction: row;
  flex-wrap: wrap;
}

#genstore-section-{{ section.id }} .product-icon-text--vertical {
  flex-direction: column;
}

#genstore-section-{{ section.id }} .product-icon-text__item {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1 1 auto;
}

#genstore-section-{{ section.id }} .product-icon-text__image img,
#genstore-section-{{ section.id }} .product-icon-text__icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  color: var(--foreground);
}

#genstore-section-{{ section.id }} .product-icon-text__icon svg {
  stroke: currentColor;
  fill: none;
  width: 100%;
  height: 100%;
}

#genstore-section-{{ section.id }} .product-icon-text__heading {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: var(--foreground);
}

/* =============================================
   QUANTITY INPUT
   ============================================= */
#genstore-section-{{ section.id }} ai-quantity-input {
  display: inline-flex;
  align-items: center;
  border: 1px solid currentColor;
  border-radius: 6px;
  overflow: hidden;
  color: var(--foreground);
  background: transparent;
}

#genstore-section-{{ section.id }} .qi-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
  width: 40px;
  height: 40px;
  color: inherit;
  font-size: 1.125rem;
  transition: background 0.15s, color 0.15s;
}

#genstore-section-{{ section.id }} .qi-btn:hover {
  background: var(--brand);
  color: var(--brand-foreground);
}

#genstore-section-{{ section.id }} .qi-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

#genstore-section-{{ section.id }} .qi-input {
  width: 48px;
  text-align: center;
  border: none;
  outline: none;
  background: transparent;
  font-size: inherit;
  color: inherit;
  -moz-appearance: textfield;
}

#genstore-section-{{ section.id }} .qi-input::-webkit-outer-spin-button,
#genstore-section-{{ section.id }} .qi-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* =============================================
   BUY BUTTONS
   ============================================= */
#genstore-section-{{ section.id }} .product-buy-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

#genstore-section-{{ section.id }} .product-form__error-message-wrapper {
  font-size: 0.875rem;
  color: var(--striking-foreground);
  background: var(--striking);
  border-radius: 6px;
  padding: 10px 14px;
}

#genstore-section-{{ section.id }} .product-gift-recipient {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 12px;
  border: 1px solid var(--secondary);
  border-radius: 8px;
  background: var(--secondary);
  color: var(--secondary-foreground);
  font-size: 0.875rem;
}

#genstore-section-{{ section.id }} .product-gift-recipient input,
#genstore-section-{{ section.id }} .product-gift-recipient textarea {
  background: transparent;
  border: 1px solid currentColor;
  border-radius: 4px;
  padding: 8px 10px;
  font-size: 0.875rem;
  color: inherit;
  width: 100%;
  outline: none;
}

#genstore-section-{{ section.id }} button.add-to-cart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 14px 28px;
  border: none;
  border-radius: 8px;
  font-size: 0.9375rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  background: var(--cta);
  color: var(--cta-foreground);
  transition: opacity 0.2s, transform 0.15s;
}

#genstore-section-{{ section.id }} button.add-to-cart-btn:hover {
  opacity: 0.88;
  transform: translateY(-1px);
}

#genstore-section-{{ section.id }} button.add-to-cart-btn:active {
  opacity: 1;
  transform: translateY(0);
}

#genstore-section-{{ section.id }} button.add-to-cart-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

#genstore-section-{{ section.id }} button.add-to-cart-btn.loading {
  opacity: 0.7;
  cursor: wait;
  transform: none;
}

#genstore-section-{{ section.id }} button.add-to-cart-btn[data-added] {
  background: var(--brand);
  color: var(--brand-foreground);
  opacity: 1;
}

/* =============================================
   DISCOUNTS & PICKUP
   ============================================= */
#genstore-section-{{ section.id }} ai-product-discounts {
  display: block;
}

#genstore-section-{{ section.id }} ai-pickup-availability {
  display: block;
  font-size: 0.875rem;
  color: var(--foreground);
  opacity: 0.75;
  padding: 6px 0;
}

/* =============================================
   STICKY CART
   ============================================= */
#genstore-section-{{ section.id }} .product-sticky-cart {
  background: var(--brand);
  color: var(--brand-foreground);
}

#genstore-section-{{ section.id }} .product-sticky-cart__variants {
  padding: 8px 0;
}

/* =============================================
   EXTRA DESCRIPTION & VIEW DETAILS
   ============================================= */
#genstore-section-{{ section.id }} .extra_desc_wrapper {
  font-size: 0.875rem;
  line-height: 1.7;
  color: var(--foreground);
  opacity: 0.75;
}

#genstore-section-{{ section.id }} a.product__view-details {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--foreground);
  opacity: 0.7;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 1px;
  transition: opacity 0.2s;
}

#genstore-section-{{ section.id }} a.product__view-details:hover {
  opacity: 1;
}

#genstore-section-{{ section.id }} a.product__view-details svg {
  stroke: currentColor;
  fill: none;
  width: 15px;
  height: 15px;
}

/* =============================================
   RESPONSIVE — MOBILE
   ============================================= */
@media screen and (max-width: 749px) {
  #genstore-section-{{ section.id }} .genstore-container {
    padding: 24px 0 40px;
  }

  #genstore-section-{{ section.id }} .product {
    gap: 24px;
  }

  #genstore-section-{{ section.id }} .product__info-container {
    gap: 16px;
    padding: 4px 0 20px;
  }

  #genstore-section-{{ section.id }} h2.product-title {
    font-size: 1.375rem;
  }

  #genstore-section-{{ section.id }} .product__media-wrapper {
    border-radius: 8px;
  }

  #genstore-section-{{ section.id }} .mg-main {
    border-radius: 8px;
    aspect-ratio: 1 / 1;
  }

  #genstore-section-{{ section.id }} button.mg-thumb {
    width: 52px;
    height: 52px;
  }

  #genstore-section-{{ section.id }} button.add-to-cart-btn {
    padding: 13px 20px;
    font-size: 0.875rem;
  }

  #genstore-section-{{ section.id }} .product-price [data-product-price] {
    font-size: 1.25rem;
  }

  #genstore-section-{{ section.id }} .vendor-and-delivery {
    gap: 10px;
  }
}

/* =============================================

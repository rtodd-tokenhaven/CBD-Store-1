    }

    #genstore-section-{{ section.id }} .product-sticky-cart__footer .sticky-cart-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    #genstore-section-{{ section.id }} .product-sticky-cart__footer .sticky-cart-btn--add {
      background: transparent;
      color: var(--foreground, #000);
      border: 1.5px solid var(--foreground, #000);
    }

    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot {
      flex: 1;
      display: flex;
      min-height: 48px;
    }

    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot:empty {
      display: none;
    }

    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot .product-buy-now {
      flex: 1;
      display: flex;
      width: 100%;
    }

    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot .product-buy-now .payment_button_container,
    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot .product-buy-now .express-pay-container,
    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot .product-buy-now button,
    #genstore-section-{{ section.id }} .product-sticky-cart__payment-slot .product-buy-now .express-buy-it-now {
      flex: 1;
      width: 100%;
      min-height: 48px;
      border-radius: 8px;
    }
  }

  @media (min-width: 750px) {
    #genstore-section-{{ section.id }} .product-sticky-cart,
    #genstore-section-{{ section.id }} .product-sticky-cart__overlay {
      display: none !important;
    }
    #genstore-section-{{ section.id }} .product {
      display: flex;
      flex-direction: row;

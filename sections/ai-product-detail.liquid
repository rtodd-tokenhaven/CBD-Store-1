    font-size: 12px;
    outline: none;
  }

  #genstore-section-{{ section.id }} .ai-share-button__message {
    position: absolute;
    top: -20px;
    left: 0;
    font-size: 11px;
    color: #2e7d32;
  }

  #genstore-section-{{ section.id }} .ai-share-button__copy,
  #genstore-section-{{ section.id }} .ai-share-button__close {

<style>
  #genstore-section-{{ section.id }} {
    {% render 'ai-color-tokens' %}
    max-width: 100vw;
    background: var(--background);
    color: var(--foreground);
  }

  #genstore-section-{{ section.id }} .section-mark {
    display: flex;
    flex-direction: column;
    min-height: 480px;
  }

  #genstore-section-{{ section.id }} .educate-split__image-panel {
    flex: 0 0 auto;
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  #genstore-section-{{ section.id }} .educate-split__image-panel img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    display: block;
  }

  #genstore-section-{{ section.id }} .educate-split__content-panel {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 48px 24px;
    background: var(--background);
    color: var(--foreground);
  }

  #genstore-section-{{ section.id }} .educate-split__label {
    display: inline-block;
    background: var(--accent);
    color: var(--accent-foreground);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 20px;
  }

  #genstore-section-{{ section.id }} .educate-split__heading {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: inherit;
  }

  #genstore-section-{{ section.id }} .educate-split__subheading {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 32px;
    color: inherit;
    opacity: 0.82;
  }

  #genstore-section-{{ section.id }} .educate-split__beats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #genstore-section-{{ section.id }} .educate-split__beat {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 0;
    border-top: 1px solid currentColor;
    opacity: 0.9;
  }

  #genstore-section-{{ section.id }} .educate-split__beat:last-child {
    border-bottom: 1px solid currentColor;
  }

  #genstore-section-{{ section.id }} .educate-split__beat-number {
    flex: 0 0 28px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent-foreground);
    background: var(--accent);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  #genstore-section-{{ section.id }} .educate-split__beat-text {
    flex: 1 1 auto;
  }

  #genstore-section-{{ section.id }} .educate-split__beat-title {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    margin: 0 0 4px;
    color: inherit;
  }

  #genstore-section-{{ section.id }} .educate-split__beat-desc {
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.55;
    margin: 0;
    color: inherit;
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    #genstore-section-{{ section.id }} .section-mark {
      flex-direction: row;
      min-height: 560px;
    }

    #genstore-section-{{ section.id }} .educate-split__image-panel {
      width: 45%;
      min-height: 560px;
    }

    #genstore-section-{{ section.id }} .educate-split__image-panel img {
      min-height: 560px;
    }

    #genstore-section-{{ section.id }} .educate-split__content-panel {
      width: 55%;
      padding: 64px 48px;
    }

    #genstore-section-{{ section.id }} .educate-split__heading {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    #genstore-section-{{ section.id }} .educate-split__image-panel {
      width: 48%;
    }

    #genstore-section-{{ section.id }} .educate-split__content-panel {
      width: 52%;
      padding: 80px 64px;
    }

    #genstore-section-{{ section.id }} .educate-split__heading {
      font-size: 2.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #genstore-section-{{ section.id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<div class="section-mark educate-split">
  <div class="educate-split__image-panel">
    {%- assign _vkey_image = '' | genstore_vkey: key:'image' -%}
    {% if section.settings.image != blank %}
      <img
        {{ _vkey_image }}
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | default: 'CBD dropper bottle beside a fresh botanical leaf on warm ivory linen' }}"
        loading="lazy"
        width="1200">
    {% else %}
      <img
        {{ _vkey_image }}
        src="https://assets-cdn.genstore.ai/web/ai-chat/static/221627f4-6050-4d8a-aee0-6d9e9299b3a0/Mock-01.png"
        alt="CBD dropper bottle beside a fresh botanical leaf on warm ivory linen"
        loading="lazy"
        width="1200">
    {% endif %}
  </div>

  <div class="educate-split__content-panel">
    {% if section.settings.label != blank %}
      <span class="educate-split__label" {{ '' | genstore_vkey: key:'label' }}>
        {{ section.settings.label | default: "Our Process" }}
      </span>
    {% endif %}

    <h2 class="educate-split__heading" {{ '' | genstore_vkey: key:'heading' }}>
      {{ section.settings.heading | default: "Sourced with Intention. Tested Without Compromise." }}
    </h2>

    <p class="educate-split__subheading" {{ '' | genstore_vkey: key:'subheading' }}>
      {{ section.settings.subheading | default: "Every bottle traces a clear line from soil to shelf. Third-party tested. Zero compromise." }}
    </p>

    {% if section.blocks.size > 0 %}
      <ul class="educate-split__beats">
        {% for block in section.blocks %}
          <li class="educate-split__beat" {{ block.genstore_attributes }}>
            <span class="educate-split__beat-number" aria-hidden="true">{{ forloop.index }}</span>
            <div class="educate-split__beat-text">
              <p class="educate-split__beat-title" {{ '' | genstore_vkey: key:'title', block:block }}>
                {{ block.settings.title | default: "Process Step" }}
              </p>
              <p class="educate-split__beat-desc" {{ '' | genstore_vkey: key:'description', block:block }}>
                {{ block.settings.description | default: "Transparent sourcing. Backed by science." }}
              </p>
            </div>
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Educate Split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sourced with Intention. Tested Without Compromise."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every bottle traces a clear line from soil to shelf. Third-party tested. Zero compromise."
    }
  ],
  "blocks": [
    {
      "type": "beat",
      "name": "Process Beat",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Beat title",
          "default": "Process Step"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beat description",
          "default": "Transparent sourcing. Backed by science."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Educate Split",
      "blocks": [
        {
          "type": "beat",
          "settings": {
            "title": "Hemp Origin",
            "description": "Single-origin hemp, grown on certified organic farms in Colorado. No pesticides. No shortcuts."
          }
        },
        {
          "type": "beat",
          "settings": {
            "title": "CO₂ Extraction",
            "description": "Cold CO₂ extraction preserves the full cannabinoid profile without residual solvents or heat degradation."
          }
        },
        {
          "type": "beat",
          "settings": {
            "title": "Third-Party Testing",
            "description": "Every batch tested by an independent ISO-certified lab. Full certificate of analysis available on every product page."
          }
        },
        {
          "type": "beat",
          "settings": {
            "title": "Quality Seal",
            "description": "Backed by nature and science — our quality seal means the potency on the label matches what is in the bottle."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}
{{ 'block-image-content.css' | asset_url | stylesheet_tag }}
{% liquid
  assign image_ratio = section.settings.image_ratio
  assign image = section.settings.image
  if section.settings.image_2 == blank
    assign show_placeholder = true
  endif
  assign box_className = 'collection-banner-box'
  assign pc_layout = section.settings.pc_layout
  assign enable_padding_top = true
  assign enable_padding_bottom = true
  assign mobile_layout = section.settings.mobile_layout
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign opacity = section.settings.image_overlay_opacity | default: 0 | divided_by: 100.0
  if opacity contains 'NaN'
    assign opacity = 0
  endif
  if pc_layout == 'image-cover'
    assign box_className = box_className | append: ' pc-image-padding-none'
  endif
  if mobile_layout == 'image-cover'
    assign box_className = box_className | append: ' mobile-image-padding-none'
  endif
  if request.url contains '/collections/all'
    assign padding_top = 'm'
    assign padding_bottom = 'm'
    assign box_className = 'collection-banner-box'
  endif
  assign  show_image_back = false
  if section.settings.enable_image == false
        assign  show_image_back = true
  elsif section.settings.enable_image == true and image == blank
        assign  show_image_back = true
  endif
%}
{% capture content %}
  <div
    class="page-width collection-banner-container 
    {%  unless  request.url contains '/collections/all' %} 
        {{ section.settings.vertical_content_alignment }} pc-{{ section.settings.pc_layout }} mobile-{{ section.settings.mobile_layout }}
    {% endunless %} 
    {% if show_image_back == true %}no-image{% endif %} 
  "
    style="--opacity: {{ opacity }};"
  >
  {% unless request.url contains '/collections/all' %}
    {% if section.settings.enable_image and image != blank %}
      <div class="collection-banner-image-wrapper">
        {%- render 'banner-media',
          image: image,
          accept_ratio: image_ratio,
          sizes: sizes,
          className: "banner-media-item collection-banner",
          widths: widths,
          fetch_priority: fetch_priority,
          show_placeholder: show_placeholder,
          visual_image_key:'image'
        -%}
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="collection-banner-content-wrapper {{ section.settings.content_alignment }} ">
        <div class="collection-banner-content-container f-column gap-800">
          {% for block in section.blocks %}
            {% if block.type == 'heading' %}
              {% liquid
                assign title = block.settings.heading
                if title == blank
                  assign title = collection.title
                endif
              %}
              {% if title != nil %}
                {% render 'genstore-heading', title: title, heading_size: block.settings.heading_size ,genstore_attributes: block.genstore_attributes ,block:block,visual_text_key:'heading'%}
              {% endif %}
            {% endif %}
            {% if block.type == 'description' %}
              {% liquid
                assign text = block.settings.text
                if text == blank
                  assign text = collection.description
                endif
              %}
              {% render 'genstore-text-block', text: text, text_size: block.settings.text_size ,genstore_attributes: block.genstore_attributes,block:block,visual_text_key:'text' %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endunless %}
  {% if  request.url contains '/collections/all'%}
    {% assign all_title ='collection-banner.all' | t   %}
    {% render 'genstore-heading', title: all_title, heading_size: "m" %}
  {% endif %}
  </div>
{% endcapture %}
{% render 'genstore-container',
  color_scheme: settings.theme_color_scheme,
  className: box_className,
  color_mode: section.settings.color_mode,
  color_style: section.settings.color_style,
  section: section,
  padding_top: padding_top,
  padding_bottom: padding_bottom,
  content: content
%}

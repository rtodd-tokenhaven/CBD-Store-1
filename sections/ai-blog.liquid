  },
  "settings": [
    {
      "default": "t:sections.featured-blog.settings.introduction.default",
      "id": "introduction",
      "label": "t:sections.featured-blog.settings.introduction.label",
      "type": "inline_richtext"
    },
    {
      "options": [
        {
          "label": "t:sections.all.size.xxs",
          "value": "xxs"
        },
        {
          "label": "t:sections.all.size.xs",
          "value": "xs"
        },
        {
          "label": "t:sections.all.size.s",
          "value": "s"
        },
        {
          "label": "t:sections.all.size.m",
          "value": "m"
        },
        {
          "label": "t:sections.all.size.l",
          "value": "l"

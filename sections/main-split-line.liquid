{% liquid
  assign border_color = section.settings.opacity
  if border_color == 'dark'
    assign border_color = 'var(--genstore-neutral-border-900)'
  endif
  if border_color == 'mid-dark'
    assign border_color = 'var(--genstore-neutral-border-250)'
  endif
  if border_color == 'light'
    assign border_color = 'var(--genstore-neutral-border-100)'
  endif
  if border_color == 'mid-light'
    assign border_color = 'var(--genstore-neutral-border-50)'
  endif
  assign line_height = section.settings.line_height | default: 1 | append: 'px'
%}

{% render 'genstore-split-line',
  color_mode: section.settings.color_mode,
  color_style: section.settings.color_style,
  padding_top: section.settings.padding_top,
  padding_bottom: section.settings.padding_bottom,
  line_mode: section.settings.line_mode,
  border_color: border_color,
  full_width: section.settings.full_width,
  line_height: line_height,
  enable_scheme: true
%}

{% schema %}
{
  "name": "t:sections.split-line.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "default": false,
      "id": "full_width",
      "label": "t:sections.all.full_width.label",
      "type": "checkbox"
    },
    {
      "default": "solid",
      "options": [
        {
          "label": "t:sections.split-line.settings.line_mode.options__1.label",
          "value": "solid"
        },
        {
          "label": "t:sections.split-line.settings.line_mode.options__2.label",

        }
      ],
      "id": "line_mode",
      "label": "t:sections.split-line.settings.line_mode.label",
      "type": "select"
    },
    {
      "type": "range",
      "id": "line_height",
      "unit": "px",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 1,
      "label": "t:sections.split-line.settings.line-height.label"
    },
    {
      "type": "select",
      "id": "opacity",
      "options": [
        {
          "label": "t:sections.split-line.settings.opacity.options__1.label",
          "value": "dark"
        },
        {
          "label": "t:sections.split-line.settings.opacity.options__2.label",
          "value": "mid-dark"
        },
        {
          "label": "t:sections.split-line.settings.opacity.options__3.label",
          "value": "light"
        },
        {
          "label": "t:sections.split-line.settings.opacity.options__4.label",
          "value": "mid-light"
        }

{% comment %}
  gap: var(--spacing-gap-3600, 72px); width: 56px; height: 56px; heading-l   大
  gap: var(--spacing-gap-2400, 48px); width: 44px; height: 44px; heading-m   中
  gap: var(--spacing-gap-1200, 24px);  width: 36px; height: 36px; heading-s  小
{% endcomment %}
{{ 'text-scroll.css' | asset_url | stylesheet_tag }}

{% liquid
  # 参数设置
  assign scroll_direction = section.settings.scroll_direction | default: 'left'
  assign hover_pause = section.settings.hover_pause | default: false
  assign gap_space = section.settings.gap_space

  # 速度映射（像素/秒）
  case section.settings.scroll_speed
    when 's'
      assign speed_px_per_sec = 80
    when 'm'
      assign speed_px_per_sec = 160
    when 'f'
      assign speed_px_per_sec = 220
    else
      assign speed_px_per_sec = 160
  endcase

  # 计算预估内容宽度（假设平均每个字符≈2px，图标≈36px，间距≈24px）
  assign estimated_char_width = 2
  assign estimated_icon_width = 0
  assign estimated_gap = 24

  # 计算单个内容块的大致宽度
  assign block_count = section.blocks | size
  if block_count > 0
    assign total_text_length = 0
    for block in section.blocks
      case block.type
        when 'text-content'
          assign total_text_length = total_text_length | plus: block.settings.scroll_text.size
        when 'image-content'
          assign estimated_icon_width = estimated_icon_width | plus: block.settings.icon_width
      endcase
    endfor

    # 计算平均每个内容块的宽度
    assign avg_block_width = estimated_icon_width | plus: estimated_gap | plus: total_text_length | times: estimated_char_width | divided_by: block_count

    # 复制次数 = (预估屏幕宽度 * 2) / 平均块宽度 (向上取整)
    # 假设最大屏幕宽度为3000px，确保至少复制2次
    assign safe_repeats = 3000 | times: 2 | divided_by: avg_block_width | at_least: 2 | at_most: 30
  else
    assign safe_repeats = 2
  endif
%}

{% capture content_item %}
  <div class="marquee-item {{ gap_space }}">
    {% for i in (1..safe_repeats) %}
      {% for block in section.blocks %}
        {%-liquid
          assign color_style_value = '--genstore-' | append: block.settings.color_style | append: '-1000'
          if block.settings.color_style == 'neutral'
            assign color_style_value = '--genstore-neutral-texticon-900'
          endif
        -%}
        <div class="scrolling-item"
          style="--color-style: var({{ color_style_value }});"
        >
          {% case block.type %}
            {% when "text-content" %}
              <a href="{{ block.settings.link_url }}"              {{ block.genstore_attributes }}
  {{ '' | genstore_vkey: key:'link_url', block:block }} class="{% if block.settings.link_url == blank %} prevent-click {% endif %}" {% if block.settings.link_url == blank %} onclick="event.preventDefault();" {% endif %}>
                {% render 'genstore-heading',
                  heading_size: block.settings.content_size,
                  title: block.settings.scroll_text,
                  visual_text_key:'scroll_text',
                  block:block
                %}
              </a>
            {% when "image-content" %}
              {%- liquid
                assign icon_width = block.settings.icon_width | default: 32
                assign thumbnail_width = icon_width | times: 2
              -%}
              <a href="{{ block.settings.link_url }}"             {{ block.genstore_attributes }}
   {{ '' | genstore_vkey: key:'link_url', block:block }}  style="width: {{ icon_width }}px;" class="{% if block.settings.link_url == blank %} prevent-click {% endif %}" {% if block.settings.link_url == blank %} onclick="event.preventDefault();" {% endif %}>
                {%- if block.settings.image != blank -%}
                  <img
                    style="height: auto; width: {{ icon_width }}px;"
                    width="{{ icon_width }}"
                    height="auto",
                    src="{{ block.settings.image | image_url: width: thumbnail_width }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    loading="lazy"
                     {{ '' | genstore_vkey: key:'image', block:block  }} 
                  >
                {%- endif -%}
                {%- if block.settings.icon != blank and block.settings.image == blank -%}
                  {%- assign file = block.settings.icon | replace: '_', '-' | prepend: 'icon-' | append: '.svg' -%}
                  <span class="svg-wrapper" {{ '' | genstore_vkey: key:'icon',block:block,value: block.settings.icon }}>{{ file | inline_asset_content }}</span>
                {%- endif -%}
              </a>
          {% endcase %}
        </div>
      {% endfor %}
    {% endfor %}
  </div>
{% endcapture %}

{% capture content %}
  <div class="marquee-container" data-speed="{{ speed_px_per_sec }}" data-direction="{{ scroll_direction }}" data-hover-pause="{{ hover_pause }}">
    <div class="marquee-content">
      <!-- 第一组项目 -->
      {% render 'only-render', content: content_item %}

      <!-- 第二组相同项目（无缝衔接） -->
      {% render 'only-render', content: content_item %}
    </div>
  </div>
{% endcapture %}

<script>
  document.addEventListener('DOMContentLoaded', initTextScroll);
  function initTextScroll() {
    const marqueeContainers = document.querySelectorAll('.marquee-container');

    marqueeContainers.forEach(container => {
      const content = container.querySelector('.marquee-content');
      const firstItem = container.querySelector('.marquee-item');
      const speed = parseFloat(container.dataset.speed);
      const direction = container.dataset.direction;
      const hoverPause = container.dataset.hoverPause === 'true';

      if (!content || !firstItem) return;

      // 检测是否为RTL布局
      const isRTL = document.documentElement.dir === 'rtl' || document.body.dir === 'rtl';

      let position = 0;
      let lastTime;
      let rafId;
      const itemWidth = firstItem.scrollWidth;

      function animate(currentTime) {
        if (!lastTime) lastTime = currentTime;
        const deltaTime = (currentTime - lastTime) / 1000; // 转换为秒
        lastTime = currentTime;

        // 根据方向更新位置 - 这里使用精确的速度计算
        if (direction === 'left') {
          position -= speed * deltaTime;
        } else {
          position += speed * deltaTime;
        }

        // 循环逻辑
        if (!isRTL) {
          if (direction === 'left' && position <= -itemWidth) {
            position += itemWidth;
          } else if (direction === 'right' && position >= 0) {
            position -= itemWidth;
          }
        } else {
          if (direction === 'left' && position <= 0) {
            position += itemWidth;
          } else if (direction === 'right' && position >= itemWidth) {
            position -= itemWidth;
          }
        }
        // 判断content是否还在DOM中, 用于编辑器修改属性时重启动画
        /**
          这2个判断太重, 有问题再加
          !document.contains(content) 判断content是否还在DOM中
          !content.closest('html') 判断content是否还在html中
        */
        if ('isConnected' in content && !content.isConnected) {
          cancelAnimationFrame(rafId);
          initTextScroll();
          return;
        }
        content.style.transform = `translateX(${position}px)`;
        rafId = requestAnimationFrame(animate);
      }

      // 初始化位置
      if (!isRTL) {
        if (direction === 'right') {
          position = -itemWidth;
        }
      } else {
        if (direction === 'left') {
          position = itemWidth;
        }
      }

      content.style.transform = `translateX(${position}px)`;

      // 开始动画
      rafId = requestAnimationFrame(animate);

      // 悬停暂停功能
      if (hoverPause) {
        container.addEventListener('mouseenter', () => {
          cancelAnimationFrame(rafId);
        });

        container.addEventListener('mouseleave', () => {
          lastTime = null; // 重置时间计算
          rafId = requestAnimationFrame(animate);
        });
      }

      // 响应式调整
      let resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          const newItemWidth = firstItem.scrollWidth;
          if (Math.abs(newItemWidth - itemWidth) > 10) {
            // 简单的重置位置逻辑，避免计算复杂化
            if (!isRTL) {
              position = direction === 'left' ? 0 : -newItemWidth;
            } else {
              position = direction === 'left' ? newItemWidth : 0;
            }
            content.style.transform = `translateX(${position}px)`;
          }
        }, 250);
      });
    });
  }
</script>


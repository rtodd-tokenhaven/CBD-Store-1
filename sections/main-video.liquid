{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{% capture video_title_content %}
   {% render 'genstore-video-blocks', section:section %}
{% endcapture %}
{% capture content %}
  {% render 'genstore-new-video',settings:section.settings,video_title_content:video_title_content,pc_cover_image_key:'cover_image',pc_image_ratio_key:'image_ratio' %}
{% endcapture %}

{% liquid
    assign className = 'video-section-container disable-section-top-offset'
  if section.settings.full_width == true
    assign className = className | append: ' full-screen'
  endif
  assign enable_padding_top = true
  assign enable_padding_bottom = true
  if section.settings.full_width == true
    assign enable_padding_top = false
    assign enable_padding_bottom = false
  endif
%}
{% render 'genstore-container',
  section: section,
  color_scheme: settings.theme_color_scheme,
  color_mode: section.settings.color_mode,
  color_style: section.settings.color_style,
  content: content,
  className: className,
  enable_padding_top: enable_padding_top,
  enable_padding_bottom: enable_padding_bottom
%}

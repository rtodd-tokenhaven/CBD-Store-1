          "id": "image_ratio",
          "label": "t:sections.video.settings.cover_image.ratio",
          "type": "select"
        },
        {
          "type": "range",
          "id": "video_width",
          "min": 50,
          "max": 300,
          "step": 5,
          "unit": "px",
          "content": "t:sections.footer.blocks.brand_information.settings.brand_image_width.label",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "t:sections.all.alignment.label",
          "options": [
            { "value": "left", "label": "t:sections.all.alignment.left" },
            { "value": "center", "label": "t:sections.all.alignment.center" },
            { "value": "right", "label": "t:sections.all.alignment.right" }
          ],
          "default": "left"
        },
        {
          "type": "checkbox",
          "id": "enable_autoplay",
          "label": "t:sections.video.settings.enable_autoplay.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "enable_video_looping",
          "label": "t:sections.video.settings.enable_video_looping.label",
          "default": false
        }
      ]
    },
    {
      "type": "liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.custom-liquid.settings.custom_liquid.label",
          "info": "t:sections.custom-liquid.settings.custom_liquid.info"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label",
      "info": "t:sections.footer.settings.header__8.info"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__3.content"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_language_selector.label",
      "info": "t:sections.footer.settings.header__6.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_country_selector.label",
      "info": "t:sections.footer.settings.header__4.info"
    },
    {
      "default": "light",
      "options": [
        { "label": "t:sections.all.color_mode.options__1.label", "value": "light" },
        { "label": "t:sections.all.color_mode.options__2.label", "value": "dark" }
      ],
      "id": "color_mode",
      "label": "t:sections.all.color_mode.label",
      "type": "select",
      "info": "t:sections.header.settings.menu_type_desktop.info"
    },
    {
      "id": "color_style",
      "label": "t:sections.all.color_style.label",
      "type": "select_draw",
      "default": "brand",
      "options": [
        { "label": "t:sections.all.color_style.transparent.label", "value": "transparent" },
        { "label": "t:sections.all.color_style.pure.label", "value": "pure" },
        { "label": "t:sections.all.color_style.neutral.label", "value": "neutral" },
        { "label": "t:sections.all.color_style.brand.label", "value": "brand" },
        { "label": "t:sections.all.color_style.secondary.label", "value": "secondary" },
        { "label": "t:sections.all.color_style.striking.label", "value": "striking" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "options": [
        { "label": "t:sections.all.padding.options__1.label", "value": "none" },
        { "label": "t:sections.all.padding.options__2.label", "value": "xxs" },
        { "label": "t:sections.all.padding.options__3.label", "value": "xs" },
        { "label": "t:sections.all.padding.options__4.label", "value": "s" },
        { "label": "t:sections.all.padding.options__5.label", "value": "m" },
        { "label": "t:sections.all.padding.options__6.label", "value": "l" },
        { "label": "t:sections.all.padding.options__7.label", "value": "xl" }
      ],
      "default": "l",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "type": "select"
    },
    {
      "options": [
        { "label": "t:sections.all.padding.options__1.label", "value": "none" },
        { "label": "t:sections.all.padding.options__2.label", "value": "xxs" },

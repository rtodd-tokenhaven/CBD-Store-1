<style>
  #genstore-section-{{ section.id }} {
    {% render 'ai-color-tokens' %}
    max-width: 100vw;
  }

  #genstore-section-{{ section.id }} .promise-bar {
    background: var(--secondary);
    color: var(--secondary-foreground);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #genstore-section-{{ section.id }} .promise-bar__inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #genstore-section-{{ section.id }} .promise-bar__items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #genstore-section-{{ section.id }} .promise-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    border-bottom: 1px solid currentColor;
    opacity: 0.85;
  }

  #genstore-section-{{ section.id }} .promise-item:last-child {
    border-bottom: none;
  }

  #genstore-section-{{ section.id }} .promise-item__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary-foreground);
  }

  #genstore-section-{{ section.id }} .promise-item__icon svg {
    width: 28px;
    height: 28px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }

  #genstore-section-{{ section.id }} .promise-item__content {
    flex: 1;
  }

  #genstore-section-{{ section.id }} .promise-item__title {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: inherit;
    margin: 0 0 2px;
    line-height: 1.3;
  }

  #genstore-section-{{ section.id }} .promise-item__desc {
    font-size: 0.82rem;
    font-weight: 400;
    color: inherit;
    opacity: 0.8;
    margin: 0;
    line-height: 1.5;
  }

  @media (min-width: 600px) {
    #genstore-section-{{ section.id }} .promise-bar__items {
      flex-direction: row;
      gap: 0;
    }

    #genstore-section-{{ section.id }} .promise-item {
      flex: 1;
      flex-direction: column;
      text-align: center;
      padding: 24px 20px;
      border-bottom: none;
      border-right: 1px solid currentColor;
      gap: 12px;
    }

    #genstore-section-{{ section.id }} .promise-item:last-child {
      border-right: none;
    }

    #genstore-section-{{ section.id }} .promise-item__icon {
      width: 48px;
      height: 48px;
    }

    #genstore-section-{{ section.id }} .promise-item__icon svg {
      width: 32px;
      height: 32px;
    }
  }

  @media (min-width: 1024px) {
    #genstore-section-{{ section.id }} .promise-bar {
      padding: 36px 48px;
    }

    #genstore-section-{{ section.id }} .promise-item {
      padding: 28px 32px;
    }

    #genstore-section-{{ section.id }} .promise-item__title {
      font-size: 1rem;
    }

    #genstore-section-{{ section.id }} .promise-item__desc {
      font-size: 0.875rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #genstore-section-{{ section.id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<div class="promise-bar section-mark">
  <div class="promise-bar__inner">
    <div class="promise-bar__items">
      {% for block in section.blocks %}
        <div class="promise-item" {{ block.genstore_attributes }}>
          <div class="promise-item__icon">
            {% case block.settings.icon %}
              {% when 'lab' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 3h6M10 3v7l-4 8a1 1 0 00.9 1.5h10.2a1 1 0 00.9-1.5l-4-8V3"/>
                  <circle cx="9" cy="14.5" r="0.75" fill="currentColor" stroke="none"/>
                  <circle cx="14" cy="16.5" r="0.75" fill="currentColor" stroke="none"/>
                </svg>
              {% when 'leaf' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 22C6 22 4 17 4 12c0-4 2-7 8-8 4-.7 7.5.5 8 5 .5 4-2 9-8 13z"/>
                  <path d="M12 22c0-6 2-10 8-14"/>
                </svg>
              {% when 'shield' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3l8 3v6c0 5-4 9-8 10C8 21 4 17 4 12V6l8-3z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              {% when 'tag' %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
                  <circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
              {% else %}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 3l8 3v6c0 5-4 9-8 10C8 21 4 17 4 12V6l8-3z"/>
                </svg>
            {% endcase %}
          </div>
          <div class="promise-item__content">
            <p class="promise-item__title" {{ '' | genstore_vkey: key:'title', block:block }}>
              {{ block.settings.title | default: "Our Promise" }}
            </p>
            <p class="promise-item__desc" {{ '' | genstore_vkey: key:'description', block:block }}>
              {{ block.settings.description | default: "" }}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Promise Icon Bar",
  "settings": [],
  "blocks": [
    {
      "type": "promise_item",
      "name": "Promise Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lab", "label": "Lab / Testing" },
            { "value": "leaf", "label": "Leaf / Organic" },
            { "value": "shield", "label": "Shield / Quality" },
            { "value": "tag", "label": "Tag / Labeling" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Promise"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Quality you can count on."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promise Icon Bar",
      "blocks": [
        {
          "type": "promise_item",
          "settings": {
            "icon": "lab",
            "title": "Third-Party Tested",
            "description": "Every batch verified by independent ISO-certified labs."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "icon": "leaf",
            "title": "Organic Sourcing",
            "description": "Hemp grown without pesticides or synthetic additives."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "icon": "shield",
            "title": "Zero Additives",
            "description": "Backed by nature and science — nothing else inside."
          }
        },
        {
          "type": "promise_item",
          "settings": {
            "icon": "tag",
            "title": "Transparent Labeling",
            "description": "Full-spectrum disclosure. Zero compromise on clarity."
          }
        }
      ]
    }
  ]
}
{% endschema %}

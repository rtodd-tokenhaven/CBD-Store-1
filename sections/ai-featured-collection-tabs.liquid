{% comment %}
  Featured Collections Tab Section
  - Displays multiple collections in a tabbed interface
  - Each block is a collection tab
{% endcomment %}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
{{ 'featured-collection-tabs.css' | asset_url | stylesheet_tag }}
{%- unless settings.card_quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'genstore-product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if settings.card_quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if settings.card_quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign color_mode = section.settings.color_mode | default: 'light'
  assign color_style = section.settings.color_style | default: 'brand'
-%}
{% capture content %}
  {% if section.blocks.size > 0 %}
    <div
    class="collection
    {% if section.settings.full_width %} full-width{% else %} page-width {% endif %} f-column gap-s"
    data-id="{{ section.id }}"
    >
      <div class="featured-collections-tab-nav {{ section.settings.heading_alignment }} f-column gap-400">
        {% if section.settings.introduction != blank %}
           {% render 'genstore-text-block',
             text: section.settings.introduction,
             text_size: section.settings.introduction_size,
             visual_text_key:'introduction'
           %}
        {% endif %}
        {% render 'genstore-tab-nav', blocks: section.blocks,control_id: section.id %}
      </div>
      <featured-collections-tab class="featured-collections-tab"  id="{{ section.id }}">
        {% for block in section.blocks %}
          <div class="tabs-content-panel {% if forloop.first %}is-selected{% endif %}" {{ block.genstore_attributes }}>
            {% render 'genstore-product-list',
                section: section,
                products_wrapper: block.settings.collection,
                products_to_show: block.settings.products_to_show,
                autoplay: block.settings.autoplay,
            %}
          </div>
        {% endfor %}
      </featured-collections-tab>
    </div>
  {% endif %}
{% endcapture %}

{% render 'genstore-container',
  color_scheme: settings.theme_color_scheme,
  color_mode: color_mode,
  color_style: color_style,
  full_width: false,
  section: section,
  className: 'featured-collection-tab-container',
  content: content
%}

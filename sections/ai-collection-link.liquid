      "type": "checkbox"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "t:sections.collection-link.settings.show_product_count.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__10.content"
    },

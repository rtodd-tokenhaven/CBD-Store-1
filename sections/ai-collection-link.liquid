{{ 'collection-link.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_mode = section.settings.color_mode | default: 'light'
  assign color_style = section.settings.color_style | default: 'brand'
-%}

{% capture container_content %}
  <genstore-collection-link
    class="
    {% if section.settings.full_width == true %} full-width {% else %} page-width {% endif %} {{ section.settings.layout_mode }}
    collection-link-box 
    image-width-{{ section.settings.image_width_pc }}
    {% if section.settings.layout_mode == 'focus' %} position-{{ section.settings.image_position }} {% endif %}
  ">
    
    <!-- 左侧文字链接 -->
    <div class="collection-link__text ">
      <ul class="collection-link-list
      {{ section.settings.text_align }}    
      {% if section.settings.layout_mode == 'text' %}  justify-content-{{ section.settings.text_align }} {% endif %}"
    >
        {%- for block in section.blocks -%}
          
          {%- assign collection = block.settings.collection -%}
          {% capture title_content %}
            {%- if collection != blank -%}
              <span>{{ collection.title }}</span>
              {%- if section.settings.show_product_count -%}  <sup>{{ collection.all_products_count }}</sup>  {%- endif -%}
            {%- else -%}
              <span>{{ "sections.collection_link.title" | t }}</span> <sup>0</sup>
            {%- endif -%}
          {% endcapture %}
             <li class="collection-link-item {% if forloop.first %}active{% endif %}"
              {{ block.genstore_attributes }}
               data-index="{{ forloop.index0 }}">
              <a href="{{ collection.url }}" {% if collection == blank or collection.url == blank %} class="prevent-click" onclick="event.preventDefault();" {% endif %}>
                {% render 'genstore-heading', title: title_content , heading_size: section.settings.heading_size %}
              </a>
            </li>
          
        {%- endfor -%}
      </ul>
    </div>    <!-- 右侧图片区域 -->
    {% if  section.settings.layout_mode == 'focus' %}
      <div class="collection-link__media image-height-{{ section.settings.image_height_pc }}" >
        {%- for block in section.blocks -%}
          <div class="collection-link__media-item  {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            {%- assign collection = block.settings.collection -%}
            {%- if collection != blank -%}
              {%- assign widths = '165, 360, 535, 750, 1070, 1500, 1920' -%}
              {{
                collection.featured_image
                | image_url: width: 1500
                | image_tag: sizes: '50vw', widths: widths 
              }}
            {%- else -%}
              <img src="{{ 'section-placeholder-3.png' | asset_url }}"/>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
  {% endif %}

 </genstore-collection-link>

{% endcapture %}
{% render 'genstore-container',
  color_scheme: settings.theme_color_scheme,
  color_mode: color_mode,
  color_style: color_style,
  section: section,
  className: 'collection-link-container',
  content: container_content
%}

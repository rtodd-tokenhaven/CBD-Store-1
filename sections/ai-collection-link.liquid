      "default": "medium",
      "options": [
        {
          "label": "t:sections.collection-link.settings.image_width_pc.options.small",
          "value": "small"
        },
        {
          "label": "t:sections.collection-link.settings.image_width_pc.options.medium",
          "value": "medium"
        },
        {

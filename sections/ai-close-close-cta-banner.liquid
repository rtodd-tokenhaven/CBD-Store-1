<style>
  #genstore-section-{{ section.id }} {
    {% render 'ai-color-tokens' %}
    max-width: 100vw;
  }

  #genstore-section-{{ section.id }} .cta-banner-wrap {
    background: var(--brand);
    color: var(--brand-foreground);
    padding: 64px 24px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  #genstore-section-{{ section.id }} .cta-banner-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #genstore-section-{{ section.id }} .cta-banner-copy {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #genstore-section-{{ section.id }} .cta-banner-heading {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
    color: var(--brand-foreground);
  }

  #genstore-section-{{ section.id }} .cta-banner-subheading {
    font-size: clamp(0.95rem, 1.8vw, 1.125rem);
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    color: var(--brand-foreground);
    opacity: 0.85;
    max-width: 540px;
  }

  #genstore-section-{{ section.id }} .cta-banner-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  #genstore-section-{{ section.id }} .cta-banner-btn {
    display: inline-block;
    background: var(--cta);
    color: var(--cta-foreground);
    padding: 14px 36px;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: opacity 0.2s ease;
  }

  #genstore-section-{{ section.id }} .cta-banner-btn:hover {
    opacity: 0.88;
  }

  #genstore-section-{{ section.id }} .cta-banner-disclaimer {
    font-size: 0.78rem;
    color: var(--brand-foreground);
    opacity: 0.6;
    margin: 0;
    line-height: 1.5;
  }

  #genstore-section-{{ section.id }} .cta-banner-divider {
    width: 48px;
    height: 2px;
    background: currentColor;
    opacity: 0.35;
    border: none;
    margin: 0;
  }

  @media (min-width: 768px) {
    #genstore-section-{{ section.id }} .cta-banner-wrap {
      padding: 80px 48px;
    }

    #genstore-section-{{ section.id }} .cta-banner-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }

    #genstore-section-{{ section.id }} .cta-banner-copy {
      flex: 1 1 0;
    }

    #genstore-section-{{ section.id }} .cta-banner-actions {
      flex-shrink: 0;
      align-items: flex-end;
    }
  }

  @media (min-width: 1024px) {
    #genstore-section-{{ section.id }} .cta-banner-wrap {
      padding: 96px 64px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #genstore-section-{{ section.id }} * {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<div class="cta-banner-wrap section-mark">
  <div class="cta-banner-inner">
    <div class="cta-banner-copy">
      <hr class="cta-banner-divider">
      <h2 class="cta-banner-heading" {{ '' | genstore_vkey: key:'heading' }}>
        {{ section.settings.heading | default: "Zero Compromise. Every Bottle." }}
      </h2>
      <p class="cta-banner-subheading" {{ '' | genstore_vkey: key:'subheading' }}>
        {{ section.settings.subheading | default: "Third-party tested. Nature-sourced. Designed to fit your daily routine without confusion or compromise." }}
      </p>
    </div>
    <div class="cta-banner-actions">
      <a
        href="{{ section.settings.button_url | default: '/collections/all' }}"
        class="cta-banner-btn"
        {{ '' | genstore_vkey: key:'button_text' | genstore_vkey: key:'button_url' }}
      >
        {{ section.settings.button_text | default: "Shop Now" }}
      </a>
      {% if section.settings.disclaimer != blank %}
        <p class="cta-banner-disclaimer" {{ '' | genstore_vkey: key:'disclaimer' }}>
          {{ section.settings.disclaimer }}
        </p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Close CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Zero Compromise. Every Bottle."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Third-party tested. Nature-sourced. Designed to fit your daily routine without confusion or compromise."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer (optional)",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Close CTA Banner",
      "settings": {
        "heading": "Zero Compromise. Every Bottle.",
        "subheading": "Third-party tested. Nature-sourced. Designed to fit your daily routine without confusion or compromise.",
        "button_text": "Shop Now",
        "disclaimer": ""
      }
    }
  ]
}
{% endschema %}
